{
  // Runtime-only path mapping for `node -r tsconfig-paths/register dist/main`.
  //
  // tsc does not rewrite path aliases, so the compiled output still contains
  // bare `require('@scrapers/...')` calls. These are the same aliases as
  // tsconfig.json, rebased from src/ onto dist/. Keep the two in sync.
  "compilerOptions": {
    "paths": {
      "@common/*": ["./dist/common/*"],
      "@config/*": ["./dist/config/*"],
      "@scrapers/*": ["./dist/scrapers/*"],
      "@ai-query/*": ["./dist/ai-query/*"],
      "@scraper-builder/*": ["./dist/scraper-builder/*"],
      "@users/*": ["./dist/users/*"]
    }
  }
}
