# Single .env at the repo root. Turbo passes these through to both apps —
# see `globalEnv` in turbo.json.

# ============================================================
# Frontend (apps/frontend)
# ============================================================

# Local Postgres from docker-compose.yml.
# Host port is 5434 to avoid colliding with other local Postgres instances.
POSTGRES_PORT=5434
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/pandorlabs

# Public origin of the app. Used for canonical URLs, OG tags, and as the
# Better Auth base URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Origin of the backend API. Must match PORT below.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Session signing secret. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET=

# Credentials the admin seed script upserts. Run `pnpm db:seed-admin` after
# setting these. The password must be at least 8 characters.
ADMIN_EMAIL=admin@pandorlabs.com
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# Resend (https://resend.com/api-keys).
RESEND_API_KEY=

# Where contact-form submissions get forwarded.
CONTACT_FORWARD_EMAIL=info@pandorlabs.com

# Sender identity used to forward submissions. Must be on a domain verified in
# Resend. Use an `onboarding@resend.dev` address only for local testing.
CONTACT_FROM_EMAIL=PandorLabs Website <onboarding@resend.dev>

# Comma-separated sender identities an admin can pick from when replying.
# Every address must be on a domain verified in Resend.
RESEND_FROM_ADDRESSES=PandorLabs <info@pandorlabs.com>,PandorLabs Sales <sales@pandorlabs.com>

# ============================================================
# Backend (apps/backend)
# Validated on boot by src/config/validation.schema.ts — the API will not
# start if a required value is missing.
# ============================================================

NODE_ENV=development
PORT=3001
# Origin allowed by the API's CORS policy.
FRONTEND_URL=http://localhost:3000

# Local Mongo and Redis from docker-compose.yml (no auth in dev).
MONGODB_URI=mongodb://localhost:27017/pandorlabs
MONGODB_MIN_POOL_SIZE=5
MONGODB_MAX_POOL_SIZE=50
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_RETRY_ATTEMPTS=3
MONGODB_RETRY_DELAY=2000

# Host port 6381 to avoid colliding with other local Redis instances. This value
# is both the docker-compose host mapping and the port the API connects to.
REDIS_HOST=localhost
REDIS_PORT=6381
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# Anthropic is the primary AI provider; the key is required.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT_MS=60000

# OpenAI is an optional secondary provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096
OPENAI_TIMEOUT_MS=60000

# API auth. Minimum 32 characters — same generator as BETTER_AUTH_SECRET above.
JWT_SECRET=
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

LOG_LEVEL=debug
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs
